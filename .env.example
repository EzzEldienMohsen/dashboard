# Copy to .env at the repo root — docker compose auto-loads this file for variable
# interpolation (separate from apps/api/.env, which the Node app itself reads).
# Required even if you only run `docker compose up -d postgres`, since compose
# interpolates every service's config up front regardless of which you start.

# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Optional — only used by the `api` service
CORS_ORIGIN=""
SENTRY_DSN=""
