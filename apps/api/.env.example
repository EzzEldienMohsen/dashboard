DATABASE_URL="postgresql://school_dashboard:school_dashboard_dev@localhost:5432/school_dashboard?schema=public"

# Auth — generate a long random value for JWT_SECRET, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="1h"
BCRYPT_SALT_ROUNDS="12"

# Observability / networking
SENTRY_DSN=""
CORS_ORIGIN="http://localhost:3001"

# Database connection pool — size to (postgres max_connections) / (replica count),
# leaving headroom for other services sharing the database.
DB_POOL_SIZE="10"
DB_POOL_IDLE_TIMEOUT_MS="30000"
DB_POOL_CONNECTION_TIMEOUT_MS="5000"

# Queries slower than this are logged as warnings (non-production only)
SLOW_QUERY_THRESHOLD_MS="200"

# Cache — set REDIS_URL to back the read cache with Redis instead of in-memory,
# which is required once you run more than one API replica.
REDIS_URL=""
