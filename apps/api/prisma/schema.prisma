// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  MANAGER
  TEACHER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         Role
  name         String
  phone        String
  country      String
  schoolId     String
  school       School   @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([schoolId])
}

model SchoolProfile {
  id           String   @id @default(cuid())
  name         String
  mission      String
  foundedYear  Int
  address      String
  contactEmail String
  contactPhone String?
  updatedAt    DateTime @updatedAt
}

enum AnnouncementCategory {
  GENERAL
  EVENT
  EXAM
  HOLIDAY
  URGENT
}

model Announcement {
  id          String               @id @default(cuid())
  title       String
  body        String
  category    AnnouncementCategory
  publishedAt DateTime             @default(now())

  @@index([publishedAt])
}

model School {
  id      String  @id @default(cuid())
  name    String
  address String?
  classes Class[]
  users   User[]
}

model Class {
  id       String    @id @default(cuid())
  name     String
  schoolId String
  school   School    @relation(fields: [schoolId], references: [id], onDelete: Cascade)
  students Student[]

  @@index([schoolId])
}

model Student {
  id         String             @id @default(cuid())
  firstName  String
  lastName   String
  classId    String
  class      Class              @relation(fields: [classId], references: [id], onDelete: Cascade)
  attendance AttendanceRecord[]
  grades     GradeRecord[]

  @@index([classId])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

model AttendanceRecord {
  id        String           @id @default(cuid())
  studentId String
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    AttendanceStatus

  @@index([studentId, date])
}

model GradeRecord {
  id         String   @id @default(cuid())
  studentId String
  student    Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject    String
  score      Float
  maxScore   Float    @default(100)
  recordedAt DateTime @default(now())

  @@index([studentId, subject])
}

// No FK to User by design — audit rows must survive user deletion.
model AuditLog {
  id           String   @id @default(cuid())
  userId       String
  action       String
  resourceType String
  resourceId   String
  timestamp    DateTime
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([resourceType, resourceId])
}
